        "x": 0,
        "y": 1,
        "w": 6,
        "h": 4
      },
      "datasource": {
        "type": "influxdb",
        "uid": "${DS_INFLUXDB}"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "string",
          "color": {
            "mode": "fixed"
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              }
            ]
          },
          "mappings": [
            {
              "type": "value",
              "options": {
                "peak": {
                  "text": "\u26a1 On Peak",
                  "color": "red",
                  "index": 0
                },
                "off_peak": {
                  "text": "\u2705 Off-Peak",
                  "color": "green",
                  "index": 1
                },
                "super_off_peak": {
                  "text": "\ud83d\udca4 Super Off-Peak",
                  "color": "blue",
                  "index": 2
                }
              }
            }
          ],
          "custom": {}
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "fields": "/^last$/",
          "values": false
        },
        "orientation": "auto",
        "colorMode": "background",
        "graphMode": "none",
        "justifyMode": "center",
        "textMode": "auto",
        "wideLayout": true
      },
      "targets": [
        {
          "datasource": {
            "type": "influxdb",
            "uid": "${DS_INFLUXDB}"
          },
          "query": "SELECT last(\"state\") FROM \"state\" WHERE \"entity_id\" = 'tou_period'",
          "rawQuery": true,
          "resultFormat": "table",
          "refId": "A"
        }
      ],
      "transformations": [
        {
          "id": "filterFieldsByName",
          "options": {
            "include": {
              "names": [
                "last"
              ]
            }
          }
        }
      ]
    },
