# Copy this file to secrets.yaml and fill in real values.
# secrets.yaml is gitignored — never commit it.
#
# Used by Home Assistant via the !secret directive.
# Reference: https://www.home-assistant.io/docs/configuration/secrets/

# Nabu Casa remote access URLs (your remote UI base URL + tab path)
nabu_casa_security_url: "https://YOUR_NABU_CASA_ID.ui.nabu.casa/lovelace/security"
nabu_casa_climate_url: "https://YOUR_NABU_CASA_ID.ui.nabu.casa/lovelace/climate"

# InfluxDB password (set when configuring the InfluxDB integration)
influxdb_password: "YOUR_INFLUXDB_PASSWORD"

# Placeholder from HA default — not actively used
some_password: "welcome"
